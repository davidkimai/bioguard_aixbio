{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/bioguard-decision-envelope.json",
  "title": "BioGuardDecisionEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "conversation_id",
    "request_ts_utc",
    "generated_at_utc",
    "model_id",
    "policy_profile",
    "decision",
    "decision_reason",
    "bkt_events",
    "host_context"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "format": "uuid"
    },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "request_ts_utc": {
      "type": "string",
      "format": "date-time"
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "model_id": {
      "type": "string"
    },
    "policy_profile": {
      "type": "object",
      "required": ["mode", "threshold_allow", "threshold_review"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["allow", "review", "block"]
        },
        "threshold_allow": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "threshold_review": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "include_bio_seq": {
          "type": "boolean"
        },
        "include_session_context": {
          "type": "boolean"
        }
      }
    },
    "decision": {
      "type": "string",
      "enum": ["allow", "review", "block"]
    },
    "decision_hash": {
      "type": "string",
      "description": "SHA-256 envelope fingerprint for audit replay"
    },
    "decision_reason": {
      "type": "string",
      "maxLength": 240
    },
    "bkt_events": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/bkt_event"
      },
      "minItems": 1
    },
    "sequence_findings": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/sequence_finding"
      }
    },
    "host_context": {
      "type": "object",
      "required": ["host_id", "skill_id", "contract_version", "artifact_version"],
      "additionalProperties": false,
      "properties": {
        "host_id": {
          "type": "string"
        },
        "skill_id": {
          "type": "string"
        },
        "contract_version": {
          "type": "string"
        },
        "artifact_version": {
          "type": "string"
        }
      }
    },
    "human_override": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "actor": {
          "type": "string"
        },
        "override_label": {
          "type": "string",
          "enum": ["allow", "review", "block"]
        },
        "override_reason": {
          "type": "string",
          "maxLength": 240
        },
        "override_ts_utc": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["actor", "override_label", "override_reason", "override_ts_utc"]
    },
    "remediation_notes": {
      "type": "string"
    }
  },
  "definitions": {
    "bkt_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "event_id",
        "conversation_id",
        "turn_index",
        "scope",
        "depth",
        "uplift",
        "composite_score",
        "composite_label",
        "source_span",
        "domain",
        "uncertainty",
        "timestamp_utc",
        "auditable"
      ],
      "properties": {
        "version": {
          "type": "string",
          "const": "bkt-v1.0"
        },
        "event_id": {
          "type": "string",
          "format": "uuid"
        },
        "conversation_id": {
          "type": "string",
          "minLength": 1
        },
        "turn_index": {
          "type": "integer",
          "minimum": 0
        },
        "scope": {
          "$ref": "#/definitions/score_dimension"
        },
        "depth": {
          "$ref": "#/definitions/score_dimension"
        },
        "uplift": {
          "$ref": "#/definitions/score_dimension"
        },
        "composite_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "composite_label": {
          "type": "string",
          "enum": ["allow", "review", "block"]
        },
        "source_span": {
          "type": "object",
          "required": ["actor", "turns", "snippet_hashes"],
          "additionalProperties": false,
          "properties": {
            "actor": {
              "type": "string",
              "enum": ["user", "assistant", "system"]
            },
            "turns": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "integer",
                "minimum": 0
              }
            },
            "snippet_hashes": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^sha256:[a-f0-9]{64}$"
              }
            }
          }
        },
        "domain": {
          "type": "string",
          "enum": ["virology", "bacterial", "synthetic-biology", "toxicology", "unknown"]
        },
        "uncertainty": {
          "type": "string",
          "enum": ["low", "med", "high"]
        },
        "model_trace": {
          "type": ["string", "null"]
        },
        "rationale": {
          "type": "string",
          "maxLength": 240
        },
        "timestamp_utc": {
          "type": "string",
          "format": "date-time"
        },
        "auditable": {
          "type": "boolean"
        }
      }
    },
    "score_dimension": {
      "type": "object",
      "required": ["score", "label", "reason"],
      "additionalProperties": false,
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "label": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "reason": {
          "type": "string",
          "maxLength": 120
        }
      }
    },
    "sequence_finding": {
      "type": "object",
      "required": ["sequence_id", "risk_label", "risk_score"],
      "additionalProperties": false,
      "properties": {
        "sequence_id": {
          "type": "string"
        },
        "risk_label": {
          "type": "string"
        },
        "risk_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
