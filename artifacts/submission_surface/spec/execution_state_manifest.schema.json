{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BioGuard Execution State Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "project",
    "program_mode",
    "attractors",
    "agent_roles",
    "milestones",
    "success_metrics"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "project": {
      "type": "string"
    },
    "program_mode": {
      "type": "string",
      "enum": ["hackathon", "fellowship", "hybrid"]
    },
    "attractors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "frame", "why_high_impact", "proof_artifact"],
        "properties": {
          "id": { "type": "string" },
          "frame": { "type": "string", "maxLength": 200 },
          "why_high_impact": { "type": "string", "maxLength": 400 },
          "proof_artifact": { "type": "string" }
        }
      }
    },
    "agent_roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "owner", "responsibilities", "inputs", "outputs", "acceptance"],
        "properties": {
          "id": { "type": "string" },
          "owner": { "type": "string" },
          "responsibilities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "inputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "outputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "acceptance": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "day", "goal", "required_outputs"],
        "properties": {
          "name": { "type": "string" },
          "day": { "type": "integer", "minimum": 0, "maximum": 30 },
          "goal": { "type": "string" },
          "required_outputs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "success_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fpr_level", "primary_metric", "min_test_items", "must_have_outputs"],
      "properties": {
        "fpr_level": { "type": "number", "minimum": 0, "maximum": 1 },
        "primary_metric": { "type": "string" },
        "min_test_items": { "type": "integer", "minimum": 1 },
        "must_have_outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "secondary_metrics": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
