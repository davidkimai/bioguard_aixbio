{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/biosession-manifest.json",
  "title": "BioSessionManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "dataset_id",
    "version",
    "license",
    "splits",
    "tiers",
    "rater_guideline_version",
    "quality_gates",
    "files",
    "created_at_utc",
    "updated_at_utc"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "const": "1.0"
    },
    "dataset_id": {
      "type": "string",
      "enum": ["bioguard-biosession"]
    },
    "version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+(\\.\\d+)?$"
    },
    "description": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "source_reference": {
      "type": "string",
      "format": "uri"
    },
    "splits": {
      "type": "object",
      "required": ["train", "dev", "test"],
      "properties": {
        "train": {
          "type": "integer",
          "minimum": 1
        },
        "dev": {
          "type": "integer",
          "minimum": 1
        },
        "test": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["tier-1-novice", "tier-2-capable", "tier-3-advanced", "tier-cbrn"]
      }
    },
    "rater_guideline_version": {
      "type": "string"
    },
    "annotation_protocol": {
      "type": "string"
    },
    "quality_gates": {
      "type": "object",
      "required": [
        "min_interrater_alpha",
        "adjudication_rounds",
        "max_unresolved_conflicts"
      ],
      "properties": {
        "min_interrater_alpha": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "adjudication_rounds": {
          "type": "integer",
          "minimum": 1
        },
        "max_unresolved_conflicts": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "split", "sha256", "num_items"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          },
          "split": {
            "type": "string",
            "enum": ["train", "dev", "test"]
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "num_items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "curation_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at_utc": {
      "type": "string",
      "format": "date-time"
    }
  }
}
